# Base URL of the app (used by Better Auth and cross-subdomain cookie derivation)
# When running inside Daytona via proxy, this is set automatically by Behave.
# Cookie domain and trusted origins are derived from this URL:
#   https://8080-xxx.proxy.epic.new → cookie domain "epic.new", trusts "https://epic.new"
#   https://8080-xxx.lvh.me:1234   → cookie domain "lvh.me", trusts "https://lvh.me"
#   http://localhost:8080           → no cross-domain (local dev)
NEXT_PUBLIC_BASE_URL=http://localhost:8080

# Auth secret (generated automatically by Behave for sandboxes)
BETTER_AUTH_SECRET=

# Database (SQLite for dev, Turso for production)
DATABASE_URL="file:./db/databases/development.db"

# Turso credentials (set by Behave when production database is provisioned)
TURSO_DATABASE_TOKEN=""

# CI environment
CI="false"
